# Copy to .env and fill in. NEVER commit a real, funded private key.

# Deployer key (throwaway for testnet only)
PRIVATE_KEY=0xyour_private_key_here

# Canonical Uniswap v4 PoolManager for the target chain.
# Ethereum Sepolia shown; leave unset to deploy a fresh PoolManager (e.g. local anvil).
POOL_MANAGER=0xE03A1074c86CFeDd5C142C4F04F1a1536e203543

# Hook constructor params
MAX_FEE_BPS=300        # 3.00%
VEST_DURATION=2592000  # 30 days, in seconds

# Set after deploying — used by script/OnchainDemo.s.sol
HOOK=0xyour_deployed_hook_address
